# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Where the frontend is served from, so the backend can redirect back after OAuth
FRONTEND_URL=http://localhost:5173

# Secret used to sign the session cookie — set to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Anthropic API key — only needed if you want the backend AI proxy (/api/claude/message)
ANTHROPIC_API_KEY=

PORT=4000
